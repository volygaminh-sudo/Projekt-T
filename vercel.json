{
  "version": 2,
  "builds": [
    {
      "src": "server/server.pg.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index/**",
          "data/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server/server.pg.js"
    }
  ]
}
