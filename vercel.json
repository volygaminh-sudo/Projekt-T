{
  "version": 2,
  "builds": [
    {
      "src": "server/server.pg.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/server.pg.js"
    },
    {
      "src": "/index/(.*)",
      "dest": "/index/$1"
    },
    {
      "src": "/",
      "dest": "/index/index.html"
    },
    {
      "src": "/(.*\\.(css|js|json|png|jpg|webp|svg|ico|mp4|woff2?))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index/$1"
    }
  ]
}
