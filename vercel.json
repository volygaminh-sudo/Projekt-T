{
  "version": 2,
  "builds": [
    {
      "src": "server/server.pg.js",
      "use": "@vercel/node"
    },
    {
      "src": "index/**",
      "use": "@vercel/static"
    },
    {
      "src": "data/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/server.pg.js"
    },
    {
      "src": "/",
      "dest": "/index/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
