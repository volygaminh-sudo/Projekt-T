{
  "version": 2,
  "builds": [
    { "src": "api/[...path].js", "use": "@vercel/node" },
    { "src": "index/**", "use": "@vercel/static" },
    { "src": "data/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index/index.html" },
    { "source": "/tier-list", "destination": "/index/tier-list.html" },
    { "source": "/capnhat", "destination": "/index/capnhat.html" },
    { "source": "/admin", "destination": "/index/admin.html" },
    { "source": "/login", "destination": "/index/login.html" },
    { "source": "/club", "destination": "/tierlist-app/club" },
    { "source": "/hero-detail\\.html", "destination": "/index/hero-detail.html" },
    { "source": "/api/(.*)", "destination": "/api/[...path].js" },
    { "source": "/((?!api/).*)", "destination": "/index/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://cdn.jsdelivr.net https://html2canvas.hertzen.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: https://lienquan.garena.vn; connect-src 'self' http://127.0.0.1:3008 https://*.vercel.app;" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
